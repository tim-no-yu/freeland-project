# Copy this file to `.env.local` and restart `npm run dev`.
# `.env.local` is gitignored so secrets / per-dev overrides stay local.

# --- Backend connection ---
# Live Django backend (Caesar's Railway deployment):
NEXT_PUBLIC_API_URL=https://earthteam-stars-backend-production-2a56.up.railway.app/api/v1

# Local Django backend (if you are running it on your own machine):
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# --- Mock data ---
# Set to "true" to use hardcoded mock data (no backend required).
# Set to "false" to make real requests against NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_USE_MOCKS=false
